{
	"name": "vantage",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:pg:generate": "drizzle-kit generate --config drizzle.postgres.config.ts",
		"db:pg:migrate": "drizzle-kit migrate --config drizzle.postgres.config.ts",
		"db:pg:push-local": "tsx scripts/push-sqlite-to-postgres.ts",
		"sync:once": "tsx scripts/sync-worker.ts --once",
		"sync:worker": "tsx scripts/sync-worker.ts",
		"source:once": "tsx scripts/source-validation-worker.ts --once",
		"source:worker": "tsx scripts/source-validation-worker.ts",
		"social:once": "tsx scripts/social-ingest-worker.ts --once",
		"social:worker": "tsx scripts/social-ingest-worker.ts",
		"media:once": "tsx scripts/media-worker.ts --once",
		"media:worker": "tsx scripts/media-worker.ts",
		"live:once": "tsx scripts/live-chunk-worker.ts --once",
		"live:worker": "tsx scripts/live-chunk-worker.ts",
		"signals:once": "tsx scripts/media-signal-worker.ts --once",
		"signals:worker": "tsx scripts/media-signal-worker.ts",
		"transcript:once": "tsx scripts/transcript-worker.ts --once",
		"transcript:worker": "tsx scripts/transcript-worker.ts",
		"translation:once": "tsx scripts/translation-worker.ts --once",
		"translation:worker": "tsx scripts/translation-worker.ts",
		"chat:once": "tsx scripts/chat-worker.ts --once",
		"chat:worker": "tsx scripts/chat-worker.ts",
		"analysis:once": "tsx scripts/analysis-worker.ts --once",
		"analysis:worker": "tsx scripts/analysis-worker.ts",
		"caption:once": "tsx scripts/caption-worker.ts --once",
		"caption:worker": "tsx scripts/caption-worker.ts",
		"preview:once": "tsx scripts/preview-worker.ts --once",
		"preview:worker": "tsx scripts/preview-worker.ts",
		"export:once": "tsx scripts/export-worker.ts --once",
		"export:worker": "tsx scripts/export-worker.ts",
		"workers:once": "tsx scripts/worker-stack.ts --once",
		"workers:stack": "tsx scripts/worker-stack.ts",
		"workers:local": "tsx scripts/worker-stack.ts --workers=sync,source,social,media,live,signals,transcript,translation,chat,analysis,caption,preview,export",
		"workers:fallback": "tsx scripts/worker-stack.ts --workers=sync,translation,chat,analysis,caption",
		"workers:local:once": "tsx scripts/worker-stack.ts --once --workers=sync,source,social,media,live,signals,transcript,translation,chat,analysis,caption,preview,export",
		"workers:fallback:once": "tsx scripts/worker-stack.ts --once --workers=sync,translation,chat,analysis,caption",
		"workers:status": "tsx scripts/worker-status.ts",
		"workers:local:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-vantage-local.ps1",
		"workers:local:configure": "powershell -ExecutionPolicy Bypass -File scripts/configure-local-worker.ps1",
		"workers:local:tray": "powershell -ExecutionPolicy Bypass -File scripts/vantage-local-tray.ps1",
		"workers:local:installer": "powershell -ExecutionPolicy Bypass -File scripts/build-vantage-local-installer.ps1",
		"workers:local:doctor": "tsx scripts/local-worker-doctor.ts",
		"workers:fallback:doctor": "tsx scripts/railway-worker-doctor.ts",
		"workers:local:install": "powershell -ExecutionPolicy Bypass -File scripts/install-local-worker-task.ps1",
		"workers:local:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-local-worker-task.ps1",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.9.3",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"better-sqlite3": "^12.10.1",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	}
}
